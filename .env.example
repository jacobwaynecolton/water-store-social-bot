# Set to true to generate content without posting to Meta (good for testing)
DRY_RUN=false

# --- AI ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# --- Meta Graph API ---
# Get these from https://developers.facebook.com/
# You need a Facebook Business Page and an Instagram Business account linked to it.
# The access token needs these permissions:
#   pages_manage_posts, pages_read_engagement,
#   instagram_basic, instagram_content_publish, instagram_manage_comments
META_ACCESS_TOKEN=your_long_lived_page_access_token_here
FACEBOOK_PAGE_ID=your_facebook_page_id_here
INSTAGRAM_ACCOUNT_ID=your_instagram_business_account_id_here

# --- Schedule ---
# Times to post each day (24h, comma-separated, server local time)
POST_TIMES=09:00,13:00,18:00

# How often to check posts for new comments (minutes)
COMMENT_CHECK_INTERVAL=30
